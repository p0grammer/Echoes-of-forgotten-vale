<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <!-- MAIN MENU UI -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/menuContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1A1A"
        android:visibility="visible">

        <ImageView
            android:id="@+id/ivMenuBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:alpha="0.4"
            android:src="@drawable/forgotten_outskirts" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="ECHOES OF THE\nFORGOTTEN VALE"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:letterSpacing="0.1"
            android:fontFamily="@font/fontfile1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/llMenuButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="48dp"
            android:layout_marginBottom="48dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/btnStartGame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="START"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:letterSpacing="0.2"
                android:fontFamily="@font/fontfile1" />

            <TextView
                android:id="@+id/btnLoadGame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOAD"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:letterSpacing="0.2"
                android:fontFamily="@font/fontfile1" />

            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETTINGS"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:letterSpacing="0.2"
                android:fontFamily="@font/fontfile1" />

            <TextView
                android:id="@+id/btnQuit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUIT"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:letterSpacing="0.2"
                android:fontFamily="@font/fontfile1" />

        </LinearLayout>

        <!-- Save Slots Container -->
        <LinearLayout
            android:id="@+id/llSaveSlots"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/medieval_panel_bg"
            android:padding="16dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvSlotTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT SLOT"
                android:textColor="#AA8844"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:textStyle="bold"
                android:fontFamily="@font/fontfile1" />

            <Button android:id="@+id/btnSlot1" android:layout_width="match_parent" android:layout_height="40dp" android:text="Slot 1 - Empty" android:background="@drawable/medieval_button_bg" android:layout_marginBottom="6dp" android:textSize="12sp" android:textColor="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/fontfile1"/>
            <Button android:id="@+id/btnSlot2" android:layout_width="match_parent" android:layout_height="40dp" android:text="Slot 2 - Empty" android:background="@drawable/medieval_button_bg" android:layout_marginBottom="6dp" android:textSize="12sp" android:textColor="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/fontfile1"/>
            <Button android:id="@+id/btnSlot3" android:layout_width="match_parent" android:layout_height="40dp" android:text="Slot 3 - Empty" android:background="@drawable/medieval_button_bg" android:layout_marginBottom="6dp" android:textSize="12sp" android:textColor="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/fontfile1"/>
            <Button android:id="@+id/btnSlot4" android:layout_width="match_parent" android:layout_height="40dp" android:text="Slot 4 - Empty" android:background="@drawable/medieval_button_bg" android:layout_marginBottom="6dp" android:textSize="12sp" android:textColor="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/fontfile1"/>
            <Button android:id="@+id/btnSlot5" android:layout_width="match_parent" android:layout_height="40dp" android:text="Slot 5 - Empty" android:background="@drawable/medieval_button_bg" android:layout_marginBottom="12dp" android:textSize="12sp" android:textColor="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/fontfile1"/>

            <TextView
                android:id="@+id/btnCancelSlots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="CANCEL"
                android:textColor="#FFFFFF"
                android:alpha="0.6"
                android:textSize="14sp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/fontfile1" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- GAMEPLAY UI -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/gameContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivBackground"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/ivCharacterAura"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.9"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.55" />

        <ImageView
            android:id="@+id/ivCharacter"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.8"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.5" />

        <!-- Stats HUD -->
        <LinearLayout
            android:id="@+id/llStatsHud"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@drawable/medieval_panel_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/tvMemoryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEMORY"
                    android:textColor="#AA8844"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <ProgressBar
                    android:id="@+id/pbMemory"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:progressDrawable="@android:drawable/progress_horizontal"
                    android:progressTint="#FFD700"
                    android:max="15" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/tvHumanityLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HUMANITY"
                    android:textColor="#AA8844"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <ProgressBar
                    android:id="@+id/pbHumanity"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:progressDrawable="@android:drawable/progress_horizontal"
                    android:progressTint="#00FFCC"
                    android:max="15" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvCorruptionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CORRUPTION"
                    android:textColor="#AA8844"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
                <ProgressBar
                    android:id="@+id/pbCorruption"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:progressDrawable="@android:drawable/progress_horizontal"
                    android:progressTint="#FF4444"
                    android:max="15" />
            </LinearLayout>
        </LinearLayout>

        <!-- Quick UI Panel -->
        <LinearLayout
            android:id="@+id/quickPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="4dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/medieval_panel_bg"
            app:layout_constraintBottom_toTopOf="@+id/vTextOverlay"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:id="@+id/btnHistory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOG" android:textColor="#AA8844" android:textSize="11sp" android:textStyle="bold" android:layout_marginEnd="12dp" android:clickable="true" android:focusable="true" android:fontFamily="@font/fontfile1" />
            <TextView android:id="@+id/btnSave" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SAVE" android:textColor="#AA8844" android:textSize="11sp" android:textStyle="bold" android:layout_marginEnd="12dp" android:clickable="true" android:focusable="true" android:fontFamily="@font/fontfile1" />
            <TextView android:id="@+id/btnSkip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SKIP" android:textColor="#AA8844" android:textSize="11sp" android:textStyle="bold" android:layout_marginEnd="12dp" android:clickable="true" android:focusable="true" android:fontFamily="@font/fontfile1" />
            <TextView android:id="@+id/btnAuto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AUTO" android:textColor="#AA8844" android:textSize="11sp" android:textStyle="bold" android:layout_marginEnd="12dp" android:clickable="true" android:focusable="true" android:fontFamily="@font/fontfile1" />
            <TextView android:id="@+id/btnSettingsInGame" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GEAR" android:textColor="#AA8844" android:textSize="11sp" android:textStyle="bold" android:layout_marginEnd="12dp" android:clickable="true" android:focusable="true" android:fontFamily="@font/fontfile1" />
            <TextView android:id="@+id/btnHide" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EYE" android:textColor="#AA8844" android:textSize="11sp" android:textStyle="bold" android:clickable="true" android:focusable="true" android:fontFamily="@font/fontfile1" />
        </LinearLayout>

        <!-- Dialogue Box -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/vTextOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:background="@drawable/medieval_panel_bg"
            android:paddingBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvSpeakerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="8dp"
                android:textColor="#AA8844"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:fontFamily="@font/fontfile1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="VAEL’THUUN" />

            <TextView
                android:id="@+id/tvSceneText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="32dp"
                android:layout_marginTop="2dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:fontFamily="serif"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvSpeakerName"
                tools:text="The Aethelroot pulses with a dim, rhythmic light..." />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Choice Container - Narrower box with centered, padded choices -->
        <ScrollView
            android:id="@+id/svChoices"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/medieval_panel_bg"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            app:layout_constraintBottom_toTopOf="@+id/quickPanel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/llStatsHud"
            app:layout_constraintVertical_bias="0.8"
            app:layout_constraintWidth_min="160dp"
            app:layout_constraintWidth_max="220dp"
            app:layout_constrainedHeight="true">

            <LinearLayout
                android:id="@+id/llChoices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </ScrollView>

        <!-- Credits Overlay -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/creditsOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FF000000"
            android:visibility="gone"
            android:elevation="25dp">

            <ScrollView
                android:id="@+id/svCredits"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/llCreditsContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="64dp"
                    android:gravity="center_horizontal">

                    <View android:layout_width="match_parent" android:layout_height="600dp" />

                    <TextView
                        android:id="@+id/tvEndingLore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textAlignment="center"
                        android:fontFamily="serif"
                        android:lineSpacingExtra="8dp" />

                    <View android:layout_width="match_parent" android:layout_height="100dp" />

                    <TextView
                        android:id="@+id/tvFullCredits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textAlignment="center"
                        android:fontFamily="serif"
                        android:lineSpacingExtra="6dp" />

                    <View android:layout_width="match_parent" android:layout_height="100dp" />

                    <TextView
                        android:id="@+id/tvCreatorCredits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#AA8844"
                        android:textSize="22sp"
                        android:textAlignment="center"
                        android:fontFamily="@font/fontfile1"
                        android:textStyle="bold"
                        android:text="ENTIRELY BUILT BY NO STRSS\n\nAI ASSISTED WORKFLOW\n\nPROMOTING THE FUTURE OF CREATIVITY\n\nSHOUTOUT TO MY MOM AND FRIENDS\nWHO CARE ABOUT ME AND MY WORK" />

                    <View android:layout_width="match_parent" android:layout_height="600dp" />

                </LinearLayout>
            </ScrollView>

            <!-- Post-Ending Menu -->
            <LinearLayout
                android:id="@+id/llPostEndingMenu"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/medieval_panel_bg"
                android:visibility="invisible"
                android:layout_marginBottom="48dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <Button
                    android:id="@+id/btnEndToMenu"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="HEAD TO MAIN MENU"
                    android:background="@drawable/medieval_button_bg"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/fontfile1"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnEndLoadSave"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="LOAD SAVE"
                    android:background="@drawable/medieval_button_bg"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/fontfile1"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- History Overlay -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/historyOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F2000000"
            android:visibility="gone"
            android:elevation="15dp">

            <TextView android:id="@+id/tvHistoryHeader" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HISTORY" android:textColor="#AA8844" android:textSize="18sp" android:letterSpacing="0.2" android:fontFamily="@font/fontfile1" android:layout_marginTop="20dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
            <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="20dp" android:layout_marginBottom="20dp" android:paddingHorizontal="40dp" app:layout_constraintTop_toBottomOf="@+id/tvHistoryHeader" app:layout_constraintBottom_toTopOf="@+id/btnBackToGame"><LinearLayout android:id="@+id/llHistoryContent" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" /></ScrollView>
            <TextView android:id="@+id/btnBackToGame" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RETURN" android:textColor="#FFFFFF" android:textSize="14sp" android:letterSpacing="0.1" android:padding="10dp" android:fontFamily="serif" android:layout_marginBottom="20dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/overlayContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="10dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
