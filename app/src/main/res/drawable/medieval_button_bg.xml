<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#18EAEAF0">
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#80161B2A" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#16EAEAF0" />
                    <padding
                        android:left="18dp"
                        android:top="12dp"
                        android:right="18dp"
                        android:bottom="12dp" />
                </shape>
            </item>
            <item android:left="14dp" android:right="14dp" android:top="12dp" android:bottom="12dp" android:gravity="bottom">
                <shape android:shape="rectangle">
                    <size android:height="2dp" />
                    <solid android:color="#44FFB86C" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
