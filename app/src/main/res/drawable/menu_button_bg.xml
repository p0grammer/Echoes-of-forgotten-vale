<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#16EAEAF0">
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <corners android:radius="16dp" />
                    <padding
                        android:left="8dp"
                        android:top="10dp"
                        android:right="8dp"
                        android:bottom="10dp" />
                </shape>
            </item>
            <item android:left="8dp" android:right="8dp" android:gravity="bottom">
                <shape android:shape="rectangle">
                    <size android:height="1dp" />
                    <solid android:color="#26EAEAF0" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
