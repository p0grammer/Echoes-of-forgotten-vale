<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#20EAEAF0">
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#99161B2A" />
                    <corners android:radius="18dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#18EAEAF0" />
                    <padding
                        android:left="18dp"
                        android:top="14dp"
                        android:right="18dp"
                        android:bottom="14dp" />
                </shape>
            </item>
            <item android:width="3dp" android:left="10dp" android:gravity="start|center_vertical">
                <shape android:shape="rectangle">
                    <solid android:color="#66FFB86C" />
                    <corners android:radius="999dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
